# Copy to .env.local for local/Codespaces dev, or set these in Vercel →
# Project → Settings → Environment Variables. Both values are PUBLIC (safe to
# expose in the browser). NEVER put the Supabase service-role key here or in
# any client code — it stays server-side only.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key
